<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.dailytask.mapper.TaskDataMapper">
    <resultMap id="TaskDataResultMap" type="com.dailytask.entity.TaskData">
        <id property="id" column="id"/>
        <result property="taskId" column="task_id"/>
        <result property="fieldId" column="field_id"/>
        <result property="fieldValue" column="field_value"/>
    </resultMap>

    <select id="findByTaskId" resultMap="TaskDataResultMap">
        SELECT id, task_id, field_id, field_value
        FROM task_data
        WHERE task_id = #{taskId}
    </select>

    <select id="findById" resultMap="TaskDataResultMap">
        SELECT id, task_id, field_id, field_value
        FROM task_data
        WHERE id = #{id}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO task_data (task_id, field_id, field_value)
        VALUES (#{taskId}, #{fieldId}, #{fieldValue})
    </insert>

    <update id="update">
        UPDATE task_data
        SET task_id = #{taskId},
            field_id = #{fieldId},
            field_value = #{fieldValue}
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM task_data WHERE id = #{id}
    </delete>

    <delete id="deleteByTaskId">
        DELETE FROM task_data WHERE task_id = #{taskId}
    </delete>
</mapper>
